<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="LearningFlashCards.Maui.ChangeEmailPage"
             Title="Change Email">

    <Grid>
        <Border StrokeThickness="0"
                StrokeShape="RoundRectangle 26"
                HorizontalOptions="Center"
                VerticalOptions="Center"
                WidthRequest="440">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#F8FAFF" Offset="0" />
                    <GradientStop Color="#EDF3FF" Offset="0.36" />
                    <GradientStop Color="#E1EAFE" Offset="1" />
                </LinearGradientBrush>
            </Border.Background>
            <Border.Shadow>
                <Shadow Brush="#245E6A91" Offset="0,16" Radius="28" Opacity="0.9" />
            </Border.Shadow>

            <VerticalStackLayout Padding="40,36" Spacing="28">

                <VerticalStackLayout Spacing="6">
                    <Label Text="Change Email"
                           Style="{StaticResource DashboardTitle}"
                           FontSize="22" />
                    <Label Text="Enter a new email address for your account"
                           Style="{StaticResource DashboardBody}" />
                </VerticalStackLayout>

                <BoxView HeightRequest="1"
                         Opacity="0.4"
                         BackgroundColor="{StaticResource DashboardBorder}" />

                <VerticalStackLayout Spacing="20">
                    <VerticalStackLayout Spacing="8">
                        <Label Text="NEW EMAIL ADDRESS"
                               Style="{StaticResource DashboardFieldLabel}" />
                        <Border Style="{StaticResource DashboardInputBorder}">
                            <Entry x:Name="EmailEntry"
                                   Keyboard="Email"
                                   IsSpellCheckEnabled="False"
                                   IsTextPredictionEnabled="False"
                                   Style="{StaticResource DashboardEntry}"
                                   Placeholder="you@example.com" />
                        </Border>
                    </VerticalStackLayout>

                    <Button Text="Save Email"
                            Style="{StaticResource DashboardPrimaryButton}"
                            Clicked="OnSaveClicked" />
                    <Button Text="Cancel"
                            Style="{StaticResource DashboardSecondaryButton}"
                            Clicked="OnCancelClicked" />
                </VerticalStackLayout>

            </VerticalStackLayout>
        </Border>
    </Grid>

</ContentPage>
