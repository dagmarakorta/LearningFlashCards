<maui:MauiWinUIApplication
    x:Class="LearningFlashCards.Maui.WinUI.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:maui="using:Microsoft.Maui"
    xmlns:local="using:LearningFlashCards.Maui.WinUI">

    <maui:MauiWinUIApplication.Resources>
        <ResourceDictionary>
            <SolidColorBrush x:Key="ScrollBarBackground" Color="#F4F7FF" />
            <SolidColorBrush x:Key="ScrollBarBackgroundPointerOver" Color="#EDF3FF" />
            <SolidColorBrush x:Key="ScrollBarBackgroundPressed" Color="#E6EEFF" />
            <SolidColorBrush x:Key="ScrollBarPanningBackground" Color="#F4F7FF" />
            <SolidColorBrush x:Key="ScrollBarPanningBackgroundPointerOver" Color="#EDF3FF" />
            <SolidColorBrush x:Key="ScrollBarPanningBackgroundPressed" Color="#E6EEFF" />
            <SolidColorBrush x:Key="ScrollBarThumbBackground" Color="#B5C7F0" />
            <SolidColorBrush x:Key="ScrollBarThumbBackgroundPointerOver" Color="#8EA5D9" />
            <SolidColorBrush x:Key="ScrollBarThumbBackgroundPressed" Color="#6E84BA" />
            <SolidColorBrush x:Key="ScrollBarPanningThumbBackground" Color="#B5C7F0" />
            <SolidColorBrush x:Key="ScrollBarPanningThumbBackgroundPointerOver" Color="#8EA5D9" />
            <SolidColorBrush x:Key="ScrollBarPanningThumbBackgroundPressed" Color="#6E84BA" />

            <Style TargetType="ScrollBar">
                <Setter Property="Background" Value="{StaticResource ScrollBarBackground}" />
                <Setter Property="Foreground" Value="{StaticResource ScrollBarThumbBackground}" />
                <Setter Property="BorderBrush" Value="{StaticResource ScrollBarBackground}" />
                <Setter Property="BorderThickness" Value="0" />
                <Setter Property="Width" Value="14" />
            </Style>
        </ResourceDictionary>
    </maui:MauiWinUIApplication.Resources>

</maui:MauiWinUIApplication>
