<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="LearningFlashCards.Maui.ImportCardsPage"
             Title="Import Cards">

    <ScrollView>
        <Grid Padding="20">
            <Border StrokeThickness="0"
                    StrokeShape="RoundRectangle 26"
                    HorizontalOptions="Center"
                    MaximumWidthRequest="760">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#4A5160" Offset="0" />
                        <GradientStop Color="#343B48" Offset="0.36" />
                        <GradientStop Color="#2B313D" Offset="1" />
                    </LinearGradientBrush>
                </Border.Background>

                <VerticalStackLayout Padding="32" Spacing="24">

                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="16">
                        <Border StrokeThickness="0"
                                StrokeShape="RoundRectangle 14"
                                BackgroundColor="#3D4A5E"
                                Padding="12,10">
                            <Label Text="📥"
                                   FontSize="24"
                                   HorizontalTextAlignment="Center"
                                   VerticalTextAlignment="Center" />
                        </Border>
                        <VerticalStackLayout Grid.Column="1" Spacing="4" VerticalOptions="Center">
                            <Label Text="Import Cards"
                                   Style="{StaticResource DashboardTitle}"
                                   FontSize="22" />
                            <Label Text="CSV format: front, back (header optional)"
                                   Style="{StaticResource DashboardBody}" />
                        </VerticalStackLayout>
                    </Grid>

                    <BoxView HeightRequest="1"
                             Opacity="0.55"
                             BackgroundColor="{StaticResource DashboardBorder}" />

                    <Border Style="{StaticResource DashboardSurfaceCard}">
                        <VerticalStackLayout Spacing="16">
                            <Label Text="CSV FILE"
                                   Style="{StaticResource DashboardFieldLabel}" />

                            <Button Text="Choose CSV File"
                                    Style="{StaticResource DashboardSecondaryButton}"
                                    HorizontalOptions="Start"
                                    Clicked="OnChooseFileClicked" />

                            <Border Stroke="{StaticResource DashboardBorder}"
                                    StrokeThickness="1"
                                    StrokeShape="RoundRectangle 10"
                                    BackgroundColor="#2C3340"
                                    Padding="12,10">
                                <VerticalStackLayout Spacing="6">
                                    <Label x:Name="FileNameLabel"
                                           Text="No file selected."
                                           Style="{StaticResource DashboardBody}" />
                                    <Label x:Name="SummaryLabel"
                                           Text="Select a CSV file to preview."
                                           Style="{StaticResource DashboardBody}"
                                           FontSize="13" />
                                </VerticalStackLayout>
                            </Border>
                        </VerticalStackLayout>
                    </Border>

                    <Border Style="{StaticResource DashboardSurfaceCard}">
                        <VerticalStackLayout Spacing="16">
                            <Label Text="DESTINATION DECK"
                                   Style="{StaticResource DashboardFieldLabel}" />

                            <Border Style="{StaticResource DashboardInputBorder}">
                                <Picker x:Name="DeckPicker"
                                        Style="{StaticResource DashboardPicker}"
                                        Title="Select a deck"
                                        ItemsSource="{Binding Decks}"
                                        ItemDisplayBinding="{Binding Name}" />
                            </Border>

                            <Border Stroke="{StaticResource DashboardBorder}"
                                    StrokeThickness="1"
                                    StrokeShape="RoundRectangle 12"
                                    BackgroundColor="#2C3340"
                                    Padding="14,10">
                                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                                    <VerticalStackLayout Spacing="2" VerticalOptions="Center">
                                        <Label Text="Create new deck instead"
                                               Style="{StaticResource DashboardSectionTitle}"
                                               FontSize="14" />
                                        <Label Text="Import cards into a brand new deck"
                                               Style="{StaticResource DashboardBody}"
                                               FontSize="12" />
                                    </VerticalStackLayout>
                                    <Switch x:Name="NewDeckSwitch"
                                            Grid.Column="1"
                                            Style="{StaticResource DashboardSwitch}"
                                            VerticalOptions="Center"
                                            Toggled="OnNewDeckToggled" />
                                </Grid>
                            </Border>
                        </VerticalStackLayout>
                    </Border>

                    <VerticalStackLayout x:Name="NewDeckFields"
                                         Spacing="16"
                                         IsVisible="False">
                        <Border Style="{StaticResource DashboardSurfaceCard}">
                            <VerticalStackLayout Spacing="16">
                                <Label Text="NEW DECK DETAILS"
                                       Style="{StaticResource DashboardFieldLabel}" />

                                <VerticalStackLayout Spacing="8">
                                    <Label Text="DECK NAME"
                                           Style="{StaticResource DashboardFieldLabel}" />
                                    <Border Style="{StaticResource DashboardInputBorder}">
                                        <Entry x:Name="NewDeckNameEntry"
                                               Style="{StaticResource DashboardEntry}"
                                               Placeholder="Example: Imported Spanish" />
                                    </Border>
                                </VerticalStackLayout>

                                <VerticalStackLayout Spacing="8">
                                    <Label Text="DESCRIPTION (OPTIONAL)"
                                           Style="{StaticResource DashboardFieldLabel}" />
                                    <Border Style="{StaticResource DashboardInputBorder}">
                                        <Editor x:Name="NewDeckDescriptionEditor"
                                                Style="{StaticResource DashboardEditor}"
                                                Placeholder="Short description for this deck"
                                                AutoSize="TextChanges"
                                                MinimumHeightRequest="90" />
                                    </Border>
                                </VerticalStackLayout>
                            </VerticalStackLayout>
                        </Border>
                    </VerticalStackLayout>

                    <VerticalStackLayout Spacing="12">
                        <Button x:Name="ImportButton"
                                Text="Import Cards"
                                Style="{StaticResource DashboardPrimaryButton}"
                                IsEnabled="False"
                                Clicked="OnImportClicked" />
                        <Button Text="Cancel"
                                Style="{StaticResource DashboardSecondaryButton}"
                                Clicked="OnCancelClicked" />
                    </VerticalStackLayout>

                </VerticalStackLayout>
            </Border>
        </Grid>
    </ScrollView>

</ContentPage>
