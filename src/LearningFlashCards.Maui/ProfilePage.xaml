<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="LearningFlashCards.Maui.ProfilePage"
             Title="Profile">

    <ScrollView>
        <Grid Padding="20">
            <Border StrokeThickness="0"
                    StrokeShape="RoundRectangle 26"
                    HorizontalOptions="Center"
                    MaximumWidthRequest="680">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#4A5160" Offset="0" />
                        <GradientStop Color="#343B48" Offset="0.36" />
                        <GradientStop Color="#2B313D" Offset="1" />
                    </LinearGradientBrush>
                </Border.Background>

                <VerticalStackLayout Padding="32" Spacing="24">

                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="16">
                        <Border StrokeThickness="0"
                                StrokeShape="RoundRectangle 16"
                                BackgroundColor="#40495A"
                                Padding="14,12">
                            <Label Text="👤"
                                   FontSize="28"
                                   HorizontalTextAlignment="Center"
                                   VerticalTextAlignment="Center" />
                        </Border>
                        <VerticalStackLayout Grid.Column="1" Spacing="4" VerticalOptions="Center">
                            <Label Text="Profile"
                                   Style="{StaticResource DashboardTitle}"
                                   FontSize="22" />
                            <Label Text="Manage your account settings"
                                   Style="{StaticResource DashboardBody}" />
                        </VerticalStackLayout>
                    </Grid>

                    <BoxView HeightRequest="1"
                             Opacity="0.55"
                             BackgroundColor="{StaticResource DashboardBorder}" />

                    <Border Style="{StaticResource DashboardSurfaceCard}">
                        <VerticalStackLayout Spacing="20">
                            <Label Text="ACCOUNT DETAILS"
                                   Style="{StaticResource DashboardFieldLabel}" />

                            <VerticalStackLayout Spacing="8">
                                <Label Text="NAME"
                                       Style="{StaticResource DashboardFieldLabel}" />
                                <Border Style="{StaticResource DashboardInputBorder}">
                                    <Entry x:Name="NameEntry"
                                           Style="{StaticResource DashboardEntry}"
                                           Placeholder="Your name" />
                                </Border>
                            </VerticalStackLayout>

                            <VerticalStackLayout Spacing="8">
                                <Label Text="EMAIL"
                                       Style="{StaticResource DashboardFieldLabel}" />
                                <Border Stroke="{StaticResource DashboardBorder}"
                                        StrokeThickness="1"
                                        StrokeShape="RoundRectangle 12"
                                        BackgroundColor="#2C3340"
                                        Padding="12,10">
                                    <Label x:Name="EmailLabel"
                                           Style="{StaticResource DashboardBody}" />
                                </Border>
                            </VerticalStackLayout>
                        </VerticalStackLayout>
                    </Border>

                    <VerticalStackLayout Spacing="12">
                        <Button Text="Save Changes"
                                Style="{StaticResource DashboardPrimaryButton}"
                                Clicked="OnSaveClicked" />
                        <Button Text="Change Email"
                                Style="{StaticResource DashboardSecondaryButton}"
                                Clicked="OnChangeEmailClicked" />

                        <BoxView HeightRequest="1"
                                 Opacity="0.3"
                                 BackgroundColor="{StaticResource DashboardBorder}"
                                 Margin="0,4" />

                        <Button Text="Logout"
                                Style="{StaticResource DashboardGhostIconButton}"
                                FontSize="15"
                                Clicked="OnLogoutClicked" />
                    </VerticalStackLayout>

                </VerticalStackLayout>
            </Border>
        </Grid>
    </ScrollView>

</ContentPage>
