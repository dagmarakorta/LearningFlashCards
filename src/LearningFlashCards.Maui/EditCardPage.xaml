<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="LearningFlashCards.Maui.EditCardPage"
             Title="Edit Card">

    <ScrollView>
        <Grid Padding="20">
            <Border StrokeThickness="0"
                    StrokeShape="RoundRectangle 26"
                    HorizontalOptions="Center"
                    MaximumWidthRequest="760">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#F8FAFF" Offset="0" />
                        <GradientStop Color="#EDF3FF" Offset="0.36" />
                        <GradientStop Color="#E1EAFE" Offset="1" />
                    </LinearGradientBrush>
                </Border.Background>

                <VerticalStackLayout Padding="32" Spacing="24">

                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="16">
                        <Border StrokeThickness="0"
                                StrokeShape="RoundRectangle 14"
                                BackgroundColor="#DDE7FF"
                                Padding="12,10">
                            <Label Text="✏️"
                                   FontSize="22"
                                   HorizontalTextAlignment="Center"
                                   VerticalTextAlignment="Center" />
                        </Border>
                        <VerticalStackLayout Grid.Column="1" Spacing="4" VerticalOptions="Center">
                            <Label Text="Edit Card"
                                   Style="{StaticResource DashboardTitle}"
                                   FontSize="22" />
                            <Label Text="Update the content of this flashcard"
                                   Style="{StaticResource DashboardBody}" />
                        </VerticalStackLayout>
                    </Grid>

                    <BoxView HeightRequest="1"
                             Opacity="0.55"
                             BackgroundColor="{StaticResource DashboardBorder}" />

                    <Border Style="{StaticResource DashboardSurfaceCard}">
                        <VerticalStackLayout Spacing="20">
                            <Label Text="FRONT SIDE"
                                   Style="{StaticResource DashboardFieldLabel}" />
                            <Border Style="{StaticResource DashboardInputBorder}">
                                <Editor x:Name="FrontEditor"
                                        Style="{StaticResource DashboardEditor}"
                                        Placeholder="Front text (supports HTML)"
                                        AutoSize="TextChanges"
                                        MinimumHeightRequest="120" />
                            </Border>
                        </VerticalStackLayout>
                    </Border>

                    <Border Style="{StaticResource DashboardSurfaceCard}">
                        <VerticalStackLayout Spacing="20">
                            <Label Text="BACK SIDE"
                                   Style="{StaticResource DashboardFieldLabel}" />
                            <Border Style="{StaticResource DashboardInputBorder}">
                                <Editor x:Name="BackEditor"
                                        Style="{StaticResource DashboardEditor}"
                                        Placeholder="Back text (supports HTML)"
                                        AutoSize="TextChanges"
                                        MinimumHeightRequest="120" />
                            </Border>
                        </VerticalStackLayout>
                    </Border>

                    <VerticalStackLayout Spacing="12">
                        <Button Text="Save Changes"
                                Style="{StaticResource DashboardPrimaryButton}"
                                Clicked="OnSaveClicked" />
                        <Button Text="Cancel"
                                Style="{StaticResource DashboardSecondaryButton}"
                                Clicked="OnCancelClicked" />
                    </VerticalStackLayout>

                </VerticalStackLayout>
            </Border>
        </Grid>
    </ScrollView>

</ContentPage>
