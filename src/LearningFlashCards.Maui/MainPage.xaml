<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="LearningFlashCards.Maui.MainPage"
             Title="Dashboard">

    <ScrollView>
        <Grid Padding="20">
            <Border StrokeThickness="0"
                    StrokeShape="RoundRectangle 26"
                    Background="{StaticResource DashboardMist}"
                    HorizontalOptions="Center"
                    MaximumWidthRequest="1480">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#4A5160" Offset="0" />
                        <GradientStop Color="#343B48" Offset="0.36" />
                        <GradientStop Color="#2B313D" Offset="1" />
                    </LinearGradientBrush>
                </Border.Background>

                <VerticalStackLayout Spacing="20">
                    <Border Stroke="{StaticResource DashboardBorder}"
                            StrokeThickness="1"
                            StrokeShape="RoundRectangle 26,26,0,0"
                            Padding="24,14">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#3C4352" Offset="0" />
                                <GradientStop Color="#333A47" Offset="1" />
                            </LinearGradientBrush>
                        </Border.Background>
                        <Grid ColumnDefinitions="*,Auto"
                              ColumnSpacing="16">
                            <HorizontalStackLayout Spacing="14"
                                                   VerticalOptions="Center">
                                <Border StrokeThickness="0"
                                        StrokeShape="RoundRectangle 12"
                                        BackgroundColor="#40495A"
                                        Padding="10,8">
                                    <Label Text="🎓"
                                           FontSize="18"
                                           TextColor="{StaticResource DashboardInk}" />
                                </Border>
                                <Label Text="Learning Flashcards"
                                       Style="{StaticResource DashboardTitle}"
                                       FontSize="18"
                                       VerticalTextAlignment="Center" />
                            </HorizontalStackLayout>

                            <HorizontalStackLayout Grid.Column="1"
                                                   Spacing="8"
                                                   VerticalOptions="Center">
                                <Button Text="Profile"
                                        Style="{StaticResource DashboardSecondaryButton}"
                                        Padding="14,8"
                                        Clicked="OnProfileClicked" />
                            </HorizontalStackLayout>
                        </Grid>
                    </Border>

                    <VerticalStackLayout Padding="26,6,26,30"
                                         Spacing="20">
                        <FlexLayout Direction="Row"
                                    Wrap="Wrap"
                                    JustifyContent="SpaceBetween"
                                    AlignItems="Center">
                            <VerticalStackLayout FlexLayout.Basis="420"
                                                 FlexLayout.Grow="1"
                                                 Spacing="8">
                                <Label Text="{Binding HeroMessage}"
                                       Style="{StaticResource DashboardHeroTitle}" />
                                <Label Text="Pick up where you left off and keep your streak going."
                                       Style="{StaticResource DashboardBody}"
                                       FontSize="15" />
                            </VerticalStackLayout>
                        </FlexLayout>

                        <FlexLayout Direction="Row"
                                    Wrap="Wrap"
                                    JustifyContent="Start"
                                    AlignItems="Start">
                            <Border Style="{StaticResource DashboardInnerCard}"
                                    WidthRequest="210"
                                    Margin="0,0,16,16">
                                <Grid RowDefinitions="Auto,Auto"
                                      ColumnDefinitions="Auto,*"
                                      ColumnSpacing="12"
                                      RowSpacing="8">
                                    <Border StrokeThickness="0"
                                            BackgroundColor="#3D4A5E"
                                            StrokeShape="RoundRectangle 12"
                                            Padding="11,9">
                                        <Label Text="🗂️"
                                               FontSize="20"
                                               HorizontalTextAlignment="Center"
                                               VerticalTextAlignment="Center" />
                                    </Border>
                                    <Label Grid.Column="1"
                                           Text="My Decks"
                                           Style="{StaticResource DashboardSectionTitle}"
                                           FontSize="15"
                                           VerticalTextAlignment="Center" />
                                    <Label Grid.Row="1"
                                           Grid.ColumnSpan="2"
                                           Text="{Binding DeckCountLabel}"
                                           Style="{StaticResource DashboardValue}" />
                                </Grid>
                            </Border>

                            <Border Style="{StaticResource DashboardInnerCard}"
                                    WidthRequest="210"
                                    Margin="0,0,16,16">
                                <Grid RowDefinitions="Auto,Auto"
                                      ColumnDefinitions="Auto,*"
                                      ColumnSpacing="12"
                                      RowSpacing="8">
                                    <Border StrokeThickness="0"
                                            BackgroundColor="#5A3A3A"
                                            StrokeShape="RoundRectangle 12"
                                            Padding="11,9">
                                        <Label Text="📅"
                                               FontSize="20"
                                               HorizontalTextAlignment="Center"
                                               VerticalTextAlignment="Center" />
                                    </Border>
                                    <Label Grid.Column="1"
                                           Text="Due Today"
                                           Style="{StaticResource DashboardSectionTitle}"
                                           FontSize="15"
                                           VerticalTextAlignment="Center" />
                                    <Label Grid.Row="1"
                                           Grid.ColumnSpan="2"
                                           Text="{Binding DueTodayCount, StringFormat='{}{0} cards'}"
                                           Style="{StaticResource DashboardValue}" />
                                </Grid>
                            </Border>

                            <Border Style="{StaticResource DashboardInnerCard}"
                                    WidthRequest="210"
                                    Margin="0,0,16,16">
                                <Grid RowDefinitions="Auto,Auto"
                                      ColumnDefinitions="Auto,*"
                                      ColumnSpacing="12"
                                      RowSpacing="8">
                                    <Border StrokeThickness="0"
                                            BackgroundColor="#5A4030"
                                            StrokeShape="RoundRectangle 12"
                                            Padding="11,9">
                                        <Label Text="🔥"
                                               FontSize="20"
                                               HorizontalTextAlignment="Center"
                                               VerticalTextAlignment="Center" />
                                    </Border>
                                    <Label Grid.Column="1"
                                           Text="Review Streak"
                                           Style="{StaticResource DashboardSectionTitle}"
                                           FontSize="15"
                                           VerticalTextAlignment="Center" />
                                    <Label Grid.Row="1"
                                           Grid.ColumnSpan="2"
                                           Text="{Binding ReviewStreakDays, StringFormat='{}{0} days'}"
                                           Style="{StaticResource DashboardValue}" />
                                </Grid>
                            </Border>

                            <Border Style="{StaticResource DashboardInnerCard}"
                                    WidthRequest="210"
                                    Margin="0,0,0,16">
                                <Grid RowDefinitions="Auto,Auto"
                                      ColumnDefinitions="Auto,*"
                                      ColumnSpacing="12"
                                      RowSpacing="8">
                                    <Border StrokeThickness="0"
                                            BackgroundColor="#364058"
                                            StrokeShape="RoundRectangle 12"
                                            Padding="11,9">
                                        <Label Text="🛡️"
                                               FontSize="20"
                                               HorizontalTextAlignment="Center"
                                               VerticalTextAlignment="Center" />
                                    </Border>
                                    <Label Grid.Column="1"
                                           Text="Mastered"
                                           Style="{StaticResource DashboardSectionTitle}"
                                           FontSize="15"
                                           VerticalTextAlignment="Center" />
                                    <Label Grid.Row="1"
                                           Grid.ColumnSpan="2"
                                           Text="{Binding MasteredCardsCount, StringFormat='{}{0} cards'}"
                                           Style="{StaticResource DashboardValue}" />
                                </Grid>
                            </Border>
                        </FlexLayout>

                        <VerticalStackLayout Spacing="20">
                            <Border Style="{StaticResource DashboardSurfaceCard}"
                                    Stroke="#454D5C">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="#323947" Offset="0" />
                                        <GradientStop Color="#2C333F" Offset="1" />
                                    </LinearGradientBrush>
                                </Border.Background>
                                <VerticalStackLayout Spacing="18">
                                    <Grid ColumnDefinitions="*,Auto"
                                          ColumnSpacing="16">
                                        <VerticalStackLayout Spacing="4">
                                            <Label Text="Choose a Deck"
                                                   Style="{StaticResource DashboardTitle}"
                                                   FontSize="20" />
                                        </VerticalStackLayout>
                                    </Grid>

                                    <BoxView HeightRequest="1"
                                             Opacity="0.55"
                                             BackgroundColor="{StaticResource DashboardBorder}" />

                                    <FlexLayout BindableLayout.ItemsSource="{Binding FeaturedDecks}"
                                                Direction="Row"
                                                Wrap="Wrap"
                                                AlignItems="Start"
                                                JustifyContent="Start">
                                        <BindableLayout.ItemTemplate>
                                            <DataTemplate>
                                                <Border Style="{StaticResource DashboardInnerCard}"
                                                        WidthRequest="295"
                                                        HeightRequest="128"
                                                        Margin="0,0,18,18"
                                                        Stroke="#596173">
                                                    <Border.Background>
                                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                            <GradientStop Color="#4B5363" Offset="0" />
                                                            <GradientStop Color="#404858" Offset="1" />
                                                        </LinearGradientBrush>
                                                    </Border.Background>
                                                    <Border.GestureRecognizers>
                                                        <TapGestureRecognizer Tapped="OnFeaturedDeckTapped" />
                                                    </Border.GestureRecognizers>

                                                    <Grid RowDefinitions="Auto,*"
                                                          ColumnDefinitions="Auto,*,Auto"
                                                          ColumnSpacing="10"
                                                          RowSpacing="8">
                                                        <Border StrokeThickness="0"
                                                                BackgroundColor="#525B6C"
                                                                StrokeShape="RoundRectangle 10"
                                                                Padding="13,11"
                                                                VerticalOptions="Start">
                                                            <Label Text="{Binding Icon}"
                                                                   FontSize="28"
                                                                   TextColor="{StaticResource DashboardInk}" />
                                                        </Border>
                                                        <VerticalStackLayout Grid.Column="1"
                                                                             Grid.ColumnSpan="2"
                                                                             Spacing="5"
                                                                             VerticalOptions="Center">
                                                            <Label Text="{Binding Name}"
                                                                   Style="{StaticResource DashboardSectionTitle}" />
                                                        </VerticalStackLayout>

                                                        <HorizontalStackLayout Grid.Row="1"
                                                                               Grid.Column="1"
                                                                               Spacing="4"
                                                                               VerticalOptions="End">
                                                            <Label Text="{Binding CardCount}"
                                                                   Style="{StaticResource DashboardValue}"
                                                                   FontSize="18"
                                                                   VerticalTextAlignment="End" />
                                                            <Label Text="Cards"
                                                                   Style="{StaticResource DashboardBody}"
                                                                   FontSize="16"
                                                                   VerticalTextAlignment="End"
                                                                   Margin="0,2,0,0" />
                                                        </HorizontalStackLayout>
                                                        <Label Grid.Row="1"
                                                               Grid.Column="2"
                                                               Text=">"
                                                               FontSize="22"
                                                               Style="{StaticResource DashboardBody}"
                                                               HorizontalTextAlignment="End"
                                                               VerticalTextAlignment="End"
                                                               VerticalOptions="End" />
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </BindableLayout.ItemTemplate>
                                    </FlexLayout>

                                    <Grid ColumnDefinitions="*,Auto,*"
                                          IsVisible="{Binding HasDecks}">
                                        <BoxView HeightRequest="1"
                                                 VerticalOptions="Center"
                                                 Opacity="0.55"
                                                 BackgroundColor="{StaticResource DashboardBorder}" />
                                        <Button Grid.Column="1"
                                                Text="Browse All Decks  >"
                                                Style="{StaticResource DashboardGhostIconButton}"
                                                FontSize="16"
                                                HorizontalOptions="Center"
                                                Clicked="OnBrowseAllDecksClicked" />
                                        <BoxView Grid.Column="2"
                                                 HeightRequest="1"
                                                 VerticalOptions="Center"
                                                 Opacity="0.55"
                                                 BackgroundColor="{StaticResource DashboardBorder}" />
                                    </Grid>

                                    <Label Text="No decks yet. Create your first one to start studying."
                                           Style="{StaticResource DashboardBody}"
                                           IsVisible="{Binding HasNoDecks}" />
                                </VerticalStackLayout>
                            </Border>

                            <FlexLayout Direction="Row"
                                        Wrap="Wrap"
                                        AlignItems="Start"
                                        JustifyContent="Start">
                                <Border Style="{StaticResource DashboardSurfaceCard}"
                                        WidthRequest="420"
                                        HeightRequest="300"
                                        Margin="0,0,20,20">
                                    <VerticalStackLayout Spacing="18">
                                        <Label Text="Progress Overview"
                                               Style="{StaticResource DashboardTitle}"
                                               FontSize="20" />
                                        <BoxView HeightRequest="1"
                                                 Opacity="0.55"
                                                 BackgroundColor="{StaticResource DashboardBorder}" />

                                        <VerticalStackLayout Spacing="8">
                                            <Grid ColumnDefinitions="*,Auto"
                                                  ColumnSpacing="10">
                                                <Label Text="Cards to Review"
                                                       Style="{StaticResource DashboardBody}" />
                                                <Label Grid.Column="1"
                                                       Text="{Binding ReviewProgressLabel}"
                                                       Style="{StaticResource DashboardSectionTitle}" />
                                            </Grid>
                                            <ProgressBar Progress="{Binding ReviewProgress}"
                                                         Style="{StaticResource DashboardProgressBar}" />
                                        </VerticalStackLayout>

                                        <VerticalStackLayout Spacing="8">
                                            <Grid ColumnDefinitions="*,Auto"
                                                  ColumnSpacing="10">
                                                <Label Text="Cards Mastered"
                                                       Style="{StaticResource DashboardBody}" />
                                                <Label Grid.Column="1"
                                                       Text="{Binding MasteredProgressLabel}"
                                                       Style="{StaticResource DashboardSectionTitle}" />
                                            </Grid>
                                            <ProgressBar Progress="{Binding MasteredProgress}"
                                                         Style="{StaticResource DashboardProgressBar}"
                                                         ProgressColor="{StaticResource DashboardSuccess}" />
                                        </VerticalStackLayout>

                                        <Border StrokeThickness="0"
                                                StrokeShape="RoundRectangle 18"
                                                BackgroundColor="#3E4553"
                                                Padding="16,14">
                                            <HorizontalStackLayout Spacing="12">
                                                <Border StrokeThickness="0"
                                                        BackgroundColor="#3D5265"
                                                        StrokeShape="RoundRectangle 12"
                                                        Padding="10,8">
                                                    <Label Text="🎯"
                                                           FontSize="18"
                                                           HorizontalTextAlignment="Center"
                                                           VerticalTextAlignment="Center" />
                                                </Border>
                                                <VerticalStackLayout Spacing="2">
                                                    <Label Text="{Binding KeepGoingMessage}"
                                                           Style="{StaticResource DashboardSectionTitle}" />
                                                    <Label Text="Consistent short sessions work best."
                                                           Style="{StaticResource DashboardBody}" />
                                                </VerticalStackLayout>
                                            </HorizontalStackLayout>
                                        </Border>
                                    </VerticalStackLayout>
                                </Border>

                                <Border Style="{StaticResource DashboardSurfaceCard}"
                                        WidthRequest="420"
                                        HeightRequest="300"
                                        Margin="0,0,20,20">
                                    <VerticalStackLayout Spacing="18">
                                        <Label Text="Daily Goal"
                                               Style="{StaticResource DashboardTitle}"
                                               FontSize="20" />
                                        <BoxView HeightRequest="1"
                                                 Opacity="0.55"
                                                 BackgroundColor="{StaticResource DashboardBorder}" />
                                        <Label Text="Daily study goal: 30 min"
                                               Style="{StaticResource DashboardSectionTitle}" />
                                        <Label Text="{Binding DailyGoalStatus}"
                                               Style="{StaticResource DashboardBody}" />
                                        <Border StrokeThickness="0"
                                                StrokeShape="RoundRectangle 18"
                                                BackgroundColor="#3E4553"
                                                Padding="18,14">
                                            <Grid ColumnDefinitions="*,Auto"
                                                  ColumnSpacing="10">
                                                <Label Text="{Binding DailyGoalSummary}"
                                                       Style="{StaticResource DashboardSectionTitle}"
                                                       VerticalTextAlignment="Center" />
                                                <Label Grid.Column="1"
                                                       Text=">"
                                                       FontSize="18"
                                                       Style="{StaticResource DashboardBody}"
                                                       VerticalTextAlignment="Center" />
                                            </Grid>
                                        </Border>
                                    </VerticalStackLayout>
                                </Border>
                            </FlexLayout>
                        </VerticalStackLayout>
                    </VerticalStackLayout>
                </VerticalStackLayout>
            </Border>
        </Grid>
    </ScrollView>

</ContentPage>
