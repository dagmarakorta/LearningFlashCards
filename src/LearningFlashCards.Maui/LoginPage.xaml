<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="LearningFlashCards.Maui.LoginPage"
             Title="Sign In">

    <Grid>
        <Border StrokeThickness="0"
                StrokeShape="RoundRectangle 26"
                HorizontalOptions="Center"
                VerticalOptions="Center"
                WidthRequest="440">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#F8FAFF" Offset="0" />
                    <GradientStop Color="#EDF3FF" Offset="0.36" />
                    <GradientStop Color="#E1EAFE" Offset="1" />
                </LinearGradientBrush>
            </Border.Background>
            <Border.Shadow>
                <Shadow Brush="#245E6A91" Offset="0,16" Radius="28" Opacity="0.9" />
            </Border.Shadow>

            <VerticalStackLayout Padding="40,36" Spacing="28">

                <VerticalStackLayout Spacing="12" HorizontalOptions="Center">
                    <Border StrokeThickness="0"
                            StrokeShape="RoundRectangle 18"
                            BackgroundColor="#FFFFFF"
                            Padding="18,14"
                            HorizontalOptions="Center">
                        <Label Text="🎓"
                               FontSize="34"
                               HorizontalTextAlignment="Center" />
                    </Border>
                    <Label Text="Learning Flashcards"
                           Style="{StaticResource DashboardTitle}"
                           FontSize="22"
                           HorizontalTextAlignment="Center" />
                    <Label Text="Sign in to continue your learning journey"
                           Style="{StaticResource DashboardBody}"
                           HorizontalTextAlignment="Center" />
                </VerticalStackLayout>

                <BoxView HeightRequest="1"
                         Opacity="0.4"
                         BackgroundColor="{StaticResource DashboardBorder}" />

                <VerticalStackLayout Spacing="20">
                    <VerticalStackLayout Spacing="8">
                        <Label Text="EMAIL ADDRESS"
                               Style="{StaticResource DashboardFieldLabel}" />
                        <Border Style="{StaticResource DashboardInputBorder}">
                            <Entry x:Name="EmailEntry"
                                   Keyboard="Email"
                                   IsSpellCheckEnabled="False"
                                   IsTextPredictionEnabled="False"
                                   Style="{StaticResource DashboardEntry}"
                                   Placeholder="you@example.com" />
                        </Border>
                    </VerticalStackLayout>

                    <Button Text="Sign In"
                            Style="{StaticResource DashboardPrimaryButton}"
                            Clicked="OnLoginClicked" />

                    <BoxView HeightRequest="1"
                             Opacity="0.3"
                             BackgroundColor="{StaticResource DashboardBorder}" />

                    <Button Text="Create new account"
                            Style="{StaticResource DashboardSecondaryButton}"
                            Clicked="OnRegisterClicked" />
                </VerticalStackLayout>

            </VerticalStackLayout>
        </Border>
    </Grid>

</ContentPage>
