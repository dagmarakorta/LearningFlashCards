<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="LearningFlashCards.Maui.BrowseDecksPage"
             Title="Browse Decks">

    <ScrollView>
        <Grid Padding="20">
            <Border StrokeThickness="0"
                    StrokeShape="RoundRectangle 26"
                    HorizontalOptions="Center"
                    MaximumWidthRequest="1180">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#4A5160" Offset="0" />
                        <GradientStop Color="#343B48" Offset="0.36" />
                        <GradientStop Color="#2B313D" Offset="1" />
                    </LinearGradientBrush>
                </Border.Background>

                <VerticalStackLayout Padding="26"
                                     Spacing="20">
                    <Grid ColumnDefinitions="*,Auto"
                          ColumnSpacing="16">
                        <VerticalStackLayout Spacing="4">
                            <Label Text="Browse Decks"
                                   Style="{StaticResource DashboardTitle}"
                                   FontSize="22" />
                            <Label Text="All your decks in one place."
                                   Style="{StaticResource DashboardBody}" />
                        </VerticalStackLayout>
                        <Button Grid.Column="1"
                                Text="New Deck"
                                Style="{StaticResource DashboardSecondaryButton}"
                                Clicked="OnNewDeckClicked" />
                    </Grid>

                    <CollectionView ItemsSource="{Binding Decks}"
                                    SelectionMode="None">
                        <CollectionView.EmptyView>
                            <Label Text="No decks yet. Create your first one."
                                   Style="{StaticResource DashboardBody}" />
                        </CollectionView.EmptyView>
                        <CollectionView.ItemsLayout>
                            <LinearItemsLayout Orientation="Vertical"
                                               ItemSpacing="16" />
                        </CollectionView.ItemsLayout>
                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <Border Style="{StaticResource DashboardSurfaceCard}">
                                    <Border.GestureRecognizers>
                                        <TapGestureRecognizer Tapped="OnDeckTapped" />
                                    </Border.GestureRecognizers>

                                    <Grid ColumnDefinitions="Auto,*,Auto,Auto"
                                          ColumnSpacing="18"
                                          RowDefinitions="Auto,Auto">
                                        <Border Grid.RowSpan="2"
                                                StrokeThickness="0"
                                                BackgroundColor="#525B6C"
                                                StrokeShape="RoundRectangle 14"
                                                Padding="18,14"
                                                VerticalOptions="Center">
                                            <Label Text="{Binding Icon}"
                                                   FontSize="24"
                                                   TextColor="{StaticResource DashboardInk}" />
                                        </Border>

                                        <VerticalStackLayout Grid.Column="1"
                                                             Spacing="4">
                                            <Label Text="{Binding Name}"
                                                   Style="{StaticResource DashboardSectionTitle}"
                                                   FontSize="22" />
                                            <Label Text="{Binding Summary}"
                                                   Style="{StaticResource DashboardBody}"
                                                   LineBreakMode="TailTruncation" />
                                        </VerticalStackLayout>

                                        <Label Grid.Row="1"
                                               Grid.Column="1"
                                               Text="{Binding CardCount, StringFormat='{}{0} cards'}"
                                               Style="{StaticResource DashboardValue}" />

                                        <HorizontalStackLayout Grid.RowSpan="2"
                                                               Grid.Column="2"
                                                               Spacing="10"
                                                               VerticalOptions="Center">
                                            <Button Text="✎"
                                                    Style="{StaticResource DashboardSecondaryButton}"
                                                    WidthRequest="54"
                                                    Padding="0"
                                                    FontSize="18"
                                                    Clicked="OnEditDeckClicked" />
                                            <Button Text="🗑"
                                                    Style="{StaticResource DashboardSecondaryButton}"
                                                    WidthRequest="54"
                                                    Padding="0"
                                                    FontSize="18"
                                                    Clicked="OnDeleteDeckClicked" />
                                        </HorizontalStackLayout>

                                        <Label Grid.RowSpan="2"
                                               Grid.Column="3"
                                               Text=">"
                                               FontSize="28"
                                               TextColor="{StaticResource DashboardMuted}"
                                               VerticalTextAlignment="Center"
                                               HorizontalTextAlignment="End"
                                               VerticalOptions="Center" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </VerticalStackLayout>
            </Border>
        </Grid>
    </ScrollView>

</ContentPage>
