<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="LearningFlashCards.Maui.RegisterPage"
             Title="Create Account">

    <Grid>
        <Border StrokeThickness="0"
                StrokeShape="RoundRectangle 26"
                HorizontalOptions="Center"
                VerticalOptions="Center"
                WidthRequest="440">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#4A5160" Offset="0" />
                    <GradientStop Color="#343B48" Offset="0.36" />
                    <GradientStop Color="#2B313D" Offset="1" />
                </LinearGradientBrush>
            </Border.Background>
            <Border.Shadow>
                <Shadow Brush="#C8000000" Offset="0,20" Radius="40" Opacity="0.55" />
            </Border.Shadow>

            <VerticalStackLayout Padding="40,36" Spacing="28">

                <VerticalStackLayout Spacing="12" HorizontalOptions="Center">
                    <Border StrokeThickness="0"
                            StrokeShape="RoundRectangle 18"
                            BackgroundColor="#40495A"
                            Padding="18,14"
                            HorizontalOptions="Center">
                        <Label Text="🎓"
                               FontSize="34"
                               HorizontalTextAlignment="Center" />
                    </Border>
                    <Label Text="Create Account"
                           Style="{StaticResource DashboardTitle}"
                           FontSize="22"
                           HorizontalTextAlignment="Center" />
                    <Label Text="Start your flashcard learning journey"
                           Style="{StaticResource DashboardBody}"
                           HorizontalTextAlignment="Center" />
                </VerticalStackLayout>

                <BoxView HeightRequest="1"
                         Opacity="0.4"
                         BackgroundColor="{StaticResource DashboardBorder}" />

                <VerticalStackLayout Spacing="20">
                    <VerticalStackLayout Spacing="8">
                        <Label Text="YOUR NAME"
                               Style="{StaticResource DashboardFieldLabel}" />
                        <Border Style="{StaticResource DashboardInputBorder}">
                            <Entry x:Name="NameEntry"
                                   Style="{StaticResource DashboardEntry}"
                                   Placeholder="Your name" />
                        </Border>
                    </VerticalStackLayout>

                    <VerticalStackLayout Spacing="8">
                        <Label Text="EMAIL ADDRESS"
                               Style="{StaticResource DashboardFieldLabel}" />
                        <Border Style="{StaticResource DashboardInputBorder}">
                            <Entry x:Name="EmailEntry"
                                   Keyboard="Email"
                                   IsSpellCheckEnabled="False"
                                   IsTextPredictionEnabled="False"
                                   Style="{StaticResource DashboardEntry}"
                                   Placeholder="you@example.com" />
                        </Border>
                    </VerticalStackLayout>

                    <Button Text="Create Account"
                            Style="{StaticResource DashboardPrimaryButton}"
                            Clicked="OnCreateClicked" />

                    <BoxView HeightRequest="1"
                             Opacity="0.3"
                             BackgroundColor="{StaticResource DashboardBorder}" />

                    <Button Text="Back to login"
                            Style="{StaticResource DashboardSecondaryButton}"
                            Clicked="OnBackClicked" />
                </VerticalStackLayout>

            </VerticalStackLayout>
        </Border>
    </Grid>

</ContentPage>
