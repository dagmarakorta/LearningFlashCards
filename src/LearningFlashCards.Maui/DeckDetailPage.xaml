<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="LearningFlashCards.Maui.DeckDetailPage"
             Title="Deck">

    <ScrollView>
        <Grid Padding="20">
            <Border StrokeThickness="0"
                    StrokeShape="RoundRectangle 26"
                    HorizontalOptions="Center"
                    MaximumWidthRequest="900">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#F8FAFF" Offset="0" />
                        <GradientStop Color="#EDF3FF" Offset="0.36" />
                        <GradientStop Color="#E1EAFE" Offset="1" />
                    </LinearGradientBrush>
                </Border.Background>

                <VerticalStackLayout Padding="32" Spacing="24">

                    <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="16">
                        <Border StrokeThickness="0"
                                StrokeShape="RoundRectangle 14"
                                BackgroundColor="#DDE7FF"
                                Padding="14,12">
                            <Label Text="📖"
                                   FontSize="26"
                                   HorizontalTextAlignment="Center"
                                   VerticalTextAlignment="Center" />
                        </Border>
                        <VerticalStackLayout Grid.Column="1" Spacing="4" VerticalOptions="Center">
                            <Label Text="{Binding DeckName}"
                                   Style="{StaticResource DashboardTitle}"
                                   FontSize="22" />
                            <Label Text="{Binding DeckDescription}"
                                   Style="{StaticResource DashboardBody}"
                                   LineBreakMode="TailTruncation" />
                        </VerticalStackLayout>
                        <HorizontalStackLayout Grid.Column="2"
                                               Spacing="10"
                                               VerticalOptions="Center">
                            <Button Text="Study"
                                    Style="{StaticResource DashboardPrimaryButton}"
                                    Padding="20,10"
                                    Clicked="OnStudyClicked" />
                            <Button Text="+ Add Card"
                                    Style="{StaticResource DashboardSecondaryButton}"
                                    Clicked="OnAddCardClicked" />
                            <Button Text="⬆ Import"
                                    Style="{StaticResource DashboardSecondaryButton}"
                                    Clicked="OnImportClicked" />
                        </HorizontalStackLayout>
                    </Grid>

                    <BoxView HeightRequest="1"
                             Opacity="0.55"
                             BackgroundColor="{StaticResource DashboardBorder}" />

                    <CollectionView ItemsSource="{Binding Cards}"
                                    SelectionMode="None">
                        <CollectionView.EmptyView>
                            <Border Style="{StaticResource DashboardSurfaceCard}">
                                <VerticalStackLayout Spacing="12"
                                                     HorizontalOptions="Center"
                                                     Padding="20">
                                    <Label Text="📭"
                                           FontSize="36"
                                           HorizontalTextAlignment="Center" />
                                    <Label Text="No cards yet"
                                           Style="{StaticResource DashboardSectionTitle}"
                                           HorizontalTextAlignment="Center" />
                                    <Label Text="Add your first card to start studying."
                                           Style="{StaticResource DashboardBody}"
                                           HorizontalTextAlignment="Center" />
                                </VerticalStackLayout>
                            </Border>
                        </CollectionView.EmptyView>
                        <CollectionView.ItemsLayout>
                            <LinearItemsLayout Orientation="Vertical" ItemSpacing="12" />
                        </CollectionView.ItemsLayout>
                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <Border Style="{StaticResource DashboardSurfaceCard}">
                                    <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="12">
                                        <VerticalStackLayout Spacing="10">
                                            <Border Stroke="{StaticResource DashboardBorder}"
                                                    StrokeThickness="1"
                                                    StrokeShape="RoundRectangle 10"
                                                    Padding="14,10">
                                                <Label Text="{Binding Front}"
                                                       Style="{StaticResource DashboardBody}"
                                                       LineBreakMode="TailTruncation"
                                                       MaxLines="4" />
                                            </Border>
                                            <Border Stroke="{StaticResource DashboardBorder}"
                                                    StrokeThickness="1"
                                                    StrokeShape="RoundRectangle 10"
                                                    Padding="14,10">
                                                <Label Text="{Binding Back}"
                                                       Style="{StaticResource DashboardBody}"
                                                       LineBreakMode="TailTruncation"
                                                       MaxLines="4" />
                                            </Border>
                                        </VerticalStackLayout>
                                        <!-- TODO: Replace emoji with image asset when available (e.g., trash.png). -->
                                        <Button Grid.Column="1"
                                                Text="✏️"
                                                Style="{StaticResource DashboardSecondaryButton}"
                                                WidthRequest="46"
                                                Padding="0"
                                                FontSize="16"
                                                VerticalOptions="Start"
                                                Clicked="OnEditCardClicked" />
                                        <Button Grid.Column="2"
                                                Text="🗑"
                                                Style="{StaticResource DashboardSecondaryButton}"
                                                WidthRequest="46"
                                                Padding="0"
                                                FontSize="16"
                                                VerticalOptions="Start"
                                                Clicked="OnDeleteCardClicked" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>

                </VerticalStackLayout>
            </Border>
        </Grid>
    </ScrollView>

</ContentPage>
