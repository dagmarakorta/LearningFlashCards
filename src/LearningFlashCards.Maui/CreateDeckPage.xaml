<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="LearningFlashCards.Maui.CreateDeckPage"
             Title="Create Deck">

    <ScrollView>
        <Grid Padding="20">
            <Border StrokeThickness="0"
                    StrokeShape="RoundRectangle 26"
                    HorizontalOptions="Center"
                    MaximumWidthRequest="760">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#F8FAFF" Offset="0" />
                        <GradientStop Color="#EDF3FF" Offset="0.36" />
                        <GradientStop Color="#E1EAFE" Offset="1" />
                    </LinearGradientBrush>
                </Border.Background>

                <VerticalStackLayout Padding="32" Spacing="24">

                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="16">
                        <Border StrokeThickness="0"
                                StrokeShape="RoundRectangle 14"
                                BackgroundColor="#DDE7FF"
                                Padding="12,10">
                            <Label Text="🗂️"
                                   FontSize="24"
                                   HorizontalTextAlignment="Center"
                                   VerticalTextAlignment="Center" />
                        </Border>
                        <VerticalStackLayout Grid.Column="1" Spacing="4" VerticalOptions="Center">
                            <Label Text="Create Deck"
                                   Style="{StaticResource DashboardTitle}"
                                   FontSize="22" />
                            <Label Text="Set up a new flashcard deck"
                                   Style="{StaticResource DashboardBody}" />
                        </VerticalStackLayout>
                    </Grid>

                    <BoxView HeightRequest="1"
                             Opacity="0.55"
                             BackgroundColor="{StaticResource DashboardBorder}" />

                    <Border Style="{StaticResource DashboardSurfaceCard}">
                        <VerticalStackLayout Spacing="20">
                            <Label Text="DECK INFO"
                                   Style="{StaticResource DashboardFieldLabel}" />

                            <VerticalStackLayout Spacing="8">
                                <Label Text="DECK NAME"
                                       Style="{StaticResource DashboardFieldLabel}" />
                                <Border Style="{StaticResource DashboardInputBorder}">
                                    <Entry x:Name="NameEntry"
                                           Style="{StaticResource DashboardEntry}"
                                           Placeholder="Example: Biology Terms" />
                                </Border>
                            </VerticalStackLayout>

                            <VerticalStackLayout Spacing="8">
                                <Label Text="DESCRIPTION"
                                       Style="{StaticResource DashboardFieldLabel}" />
                                <Border Style="{StaticResource DashboardInputBorder}">
                                    <Editor x:Name="DescriptionEditor"
                                            Style="{StaticResource DashboardEditor}"
                                            Placeholder="Short description for this deck"
                                            AutoSize="TextChanges"
                                            MinimumHeightRequest="90" />
                                </Border>
                            </VerticalStackLayout>
                        </VerticalStackLayout>
                    </Border>

                    <Border Style="{StaticResource DashboardSurfaceCard}">
                        <VerticalStackLayout Spacing="20">
                            <Label Text="STUDY SETTINGS"
                                   Style="{StaticResource DashboardFieldLabel}" />

                            <VerticalStackLayout Spacing="8">
                                <Label Text="DAILY REVIEW LIMIT"
                                       Style="{StaticResource DashboardFieldLabel}" />
                                <Border Style="{StaticResource DashboardInputBorder}">
                                    <Entry x:Name="DailyLimitEntry"
                                           Style="{StaticResource DashboardEntry}"
                                           Keyboard="Numeric" />
                                </Border>
                            </VerticalStackLayout>

                            <VerticalStackLayout Spacing="8">
                                <Label Text="EASY MINIMUM INTERVAL (DAYS)"
                                       Style="{StaticResource DashboardFieldLabel}" />
                                <Border Style="{StaticResource DashboardInputBorder}">
                                    <Entry x:Name="EasyMinIntervalEntry"
                                           Style="{StaticResource DashboardEntry}"
                                           Keyboard="Numeric" />
                                </Border>
                            </VerticalStackLayout>

                            <VerticalStackLayout Spacing="8">
                                <Label Text="MAX INTERVAL (DAYS)"
                                       Style="{StaticResource DashboardFieldLabel}" />
                                <Border Style="{StaticResource DashboardInputBorder}">
                                    <Entry x:Name="MaxIntervalEntry"
                                           Style="{StaticResource DashboardEntry}"
                                           Keyboard="Numeric" />
                                </Border>
                            </VerticalStackLayout>

                            <Border Stroke="{StaticResource DashboardBorder}"
                                    StrokeThickness="1"
                                    StrokeShape="RoundRectangle 12"
                                    BackgroundColor="{StaticResource DashboardChip}"
                                    Padding="14,10">
                                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                                    <VerticalStackLayout Spacing="2" VerticalOptions="Center">
                                        <Label Text="Repeat Again / Hard in session"
                                               Style="{StaticResource DashboardSectionTitle}"
                                               FontSize="14" />
                                        <Label Text="Repeat difficult cards within the same session"
                                               Style="{StaticResource DashboardBody}"
                                               FontSize="12" />
                                    </VerticalStackLayout>
                                    <Switch x:Name="RepeatInSessionSwitch"
                                            Grid.Column="1"
                                            Style="{StaticResource DashboardSwitch}"
                                            VerticalOptions="Center" />
                                </Grid>
                            </Border>
                        </VerticalStackLayout>
                    </Border>

                    <VerticalStackLayout Spacing="12">
                        <Button Text="Save Deck"
                                Style="{StaticResource DashboardPrimaryButton}"
                                Clicked="OnSaveClicked" />
                        <Button Text="Cancel"
                                Style="{StaticResource DashboardSecondaryButton}"
                                Clicked="OnCancelClicked" />
                    </VerticalStackLayout>

                </VerticalStackLayout>
            </Border>
        </Grid>
    </ScrollView>

</ContentPage>
