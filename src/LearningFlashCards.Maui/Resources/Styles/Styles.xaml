    <!-- Dashboard form element styles -->
    <Style TargetType="Entry" x:Key="DashboardEntry">
        <Setter Property="TextColor" Value="{StaticResource DashboardInk}" />
        <Setter Property="BackgroundColor" Value="Transparent" />
        <Setter Property="PlaceholderColor" Value="{StaticResource DashboardMuted}" />
        <Setter Property="FontFamily" Value="OpenSansRegular" />
        <Setter Property="FontSize" Value="15" />
        <Setter Property="MinimumHeightRequest" Value="44" />
    </Style>

    <Style TargetType="Editor" x:Key="DashboardEditor">
        <Setter Property="TextColor" Value="{StaticResource DashboardInk}" />
        <Setter Property="BackgroundColor" Value="Transparent" />
        <Setter Property="PlaceholderColor" Value="{StaticResource DashboardMuted}" />
        <Setter Property="FontFamily" Value="OpenSansRegular" />
        <Setter Property="FontSize" Value="15" />
    </Style>

    <Style TargetType="Border" x:Key="DashboardInputBorder">
        <Setter Property="Stroke" Value="{StaticResource DashboardBorder}" />
