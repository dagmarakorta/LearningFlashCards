@page "/study/{DeckId:guid}"
@rendermode @(new InteractiveWebAssemblyRenderMode(prerender: false))
@inject ApiClient Api
@inject UserSessionService Session
@inject NavigationManager Nav
@using LearningFlashCards.Core.Domain.Entities
@using LearningFlashCards.Core.Domain.Study

<PageTitle>Nauka – LearningFlashCards</PageTitle>

@if (!initialized)
{
    <div class="loading-spinner">Ładowanie...</div>
}
else if (sessionDone)
{
    <div class="study-done">
        <div class="study-done-card">
            <div class="done-icon">🎉</div>
            <h2>Sesja zakończona!</h2>
            <p>Powtórzono <strong>@reviewedCount</strong> kart.</p>
            <div class="d-flex gap-3 justify-content-center mt-3">
                <a href="/" class="btn btn-secondary">Powrót do talii</a>
                <button class="btn btn-primary" @onclick="RestartSession">Ucz się dalej</button>
            </div>
        </div>
    </div>
}
else if (currentCard is null)
{
    <div class="study-done">
        <div class="study-done-card">
            <h2>Brak kart do powtórzenia</h2>
            <p>Wszystkie karty są aktualne. Wróć jutro!</p>
            <a href="/" class="btn btn-primary">Powrót</a>
        </div>
    </div>
}
else
{
    <div class="study-header">
        <a href="/deck/@DeckId" class="back-link">← @deckName</a>
        <span class="progress-info">@reviewedCount / @totalQueue kart</span>
    </div>

    <div class="progress mb-3">
        <div class="progress-bar" style="width: @(totalQueue > 0 ? (reviewedCount * 100 / totalQueue) : 0)%"></div>
    </div>

    <div class="flashcard @(showBack ? "flipped" : "")" @onclick="ShowBack">
        <div class="flashcard-inner">
            <div class="flashcard-front">
                <div class="flashcard-content">@currentCard.Front</div>
                <div class="flip-hint">Kliknij, aby zobaczyć odpowiedź</div>
            </div>
            <div class="flashcard-back">
                <div class="flashcard-content">@currentCard.Back</div>
                @if (!string.IsNullOrEmpty(currentCard.Notes))
                {
                    <div class="card-notes">@currentCard.Notes</div>
                }
            </div>
        </div>
    </div>

    @if (showBack)
    {
        <div class="rating-buttons">
            <button class="btn rating-btn rating-again" @onclick="() => RateAsync(CardReviewRating.Again)">
                <span class="rating-emoji">❌</span>
                <span>Jeszcze raz</span>
            </button>
            <button class="btn rating-btn rating-hard" @onclick="() => RateAsync(CardReviewRating.Hard)">
                <span class="rating-emoji">😓</span>
                <span>Trudne</span>
            </button>
            <button class="btn rating-btn rating-medium" @onclick="() => RateAsync(CardReviewRating.Medium)">
                <span class="rating-emoji">🙂</span>
                <span>Dobrze</span>
            </button>
            <button class="btn rating-btn rating-easy" @onclick="() => RateAsync(CardReviewRating.Easy)">
                <span class="rating-emoji">⭐</span>
                <span>Łatwe</span>
            </button>
        </div>
    }
}

@code {
    [Parameter] public Guid DeckId { get; set; }

    private string deckName = "";
    private Queue<Card> queue = new();
    private Card? currentCard;
    private bool showBack;
    private bool initialized;
    private bool sessionDone;
    private int reviewedCount;
    private int totalQueue;

    protected override async Task OnInitializedAsync()
    {
        var ownerId = await Session.GetOwnerIdAsync();
        if (!ownerId.HasValue)
        {
            Nav.NavigateTo("/login");
            return;
        }

        var deck = await Api.GetDeckAsync(DeckId);
        deckName = deck?.Name ?? "Talia";

        var cards = await Api.GetCardsAsync(DeckId);
        var now = DateTimeOffset.UtcNow;
        var due = cards.Where(c => c.State.DueAt <= now).OrderBy(c => c.State.DueAt).ToList();

        queue = new Queue<Card>(due);
        totalQueue = due.Count;
        initialized = true;

        NextCard();
    }

    private void NextCard()
    {
        showBack = false;
        currentCard = queue.Count > 0 ? queue.Dequeue() : null;

        if (currentCard is null && reviewedCount > 0)
            sessionDone = true;
    }

    private void ShowBack()
    {
        if (!showBack)
            showBack = true;
    }

    private async Task RateAsync(CardReviewRating rating)
    {
        if (currentCard is null) return;

        SpacedRepetitionScheduler.ApplyRating(currentCard.State, rating, DateTimeOffset.UtcNow);

        if (rating == CardReviewRating.Again)
            queue.Enqueue(currentCard);

        await Api.UpsertCardAsync(DeckId, new
        {
            Id = currentCard.Id,
            Front = currentCard.Front,
            Back = currentCard.Back,
            Notes = currentCard.Notes,
            State = new
            {
                DueAt = currentCard.State.DueAt,
                IntervalDays = currentCard.State.IntervalDays,
                EaseFactor = currentCard.State.EaseFactor,
                Streak = currentCard.State.Streak,
                Lapses = currentCard.State.Lapses
            }
        });

        reviewedCount++;
        NextCard();
    }

    private void RestartSession()
    {
        sessionDone = false;
        reviewedCount = 0;
    }
}
