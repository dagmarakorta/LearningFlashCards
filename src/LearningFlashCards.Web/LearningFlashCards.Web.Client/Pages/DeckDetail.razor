@page "/deck/{DeckId:guid}"
@rendermode @(new InteractiveWebAssemblyRenderMode(prerender: false))
@inject ApiClient Api
@inject UserSessionService Session
@inject NavigationManager Nav
@using Microsoft.AspNetCore.Components
@using LearningFlashCards.Core.Application.Import
@using Microsoft.AspNetCore.Components.Forms
@inject Microsoft.JSInterop.IJSRuntime Js

<PageTitle>@(deckName == string.Empty ? "Deck" : deckName) - LearningFlashCards</PageTitle>

@if (!initialized)
{
    <div class="deck-detail-loading">Loading deck...</div>
}
else if (deckName == string.Empty)
{
    <div class="deck-detail-loading">Deck not found.</div>
}
else
{
    <div class="deck-detail-page">
        <div class="deck-detail-frame">
            <section class="deck-detail-shell">
                <div class="deck-detail-header">
                    <div class="deck-detail-monogram">@DeckMonogram</div>
                    <div class="deck-detail-copy">
                        <h1>@deckName</h1>
                        <p>@DeckDescription</p>
                    </div>
                    <div class="deck-detail-header-actions">
                        <button type="button" class="deck-detail-primary-button" @onclick="GoToStudy">Study</button>
                        <button type="button" class="deck-detail-secondary-button" @onclick="GoToAddCard">Add Card</button>
                        <button type="button" class="deck-detail-secondary-button" @onclick="OpenImportPicker">Import</button>
                    </div>
                </div>

                <InputFile id="deck-import-input" OnChange="OnFileSelected" accept=".csv" class="deck-detail-hidden-file-input" style="display: none;" />

                <div class="deck-detail-divider"></div>

                @if (showStudyDoneMessage)
                {
                    <div class="deck-detail-success">You've completed all due cards for now.</div>
                }

                @if (showImportDialog)
                {
                    <div class="deck-detail-modal-backdrop">
                        <section class="deck-detail-import-modal">
                            <h2>Import Cards</h2>
                            <p>CSV format: front, back (header optional)</p>

                            <div class="deck-detail-file-summary">
                                <div>@ImportFileTitle</div>
                                <div class="deck-detail-file-summary-body">@ImportFileBody</div>
                            </div>

                            @if (!string.IsNullOrWhiteSpace(importSummary))
                            {
                                <div class="@(importHasErrors ? "deck-detail-inline-error" : "deck-detail-inline-success")">@importSummary</div>
                            }

                            @if (importError is not null)
                            {
                                <div class="deck-detail-error">@importError</div>
                            }

                            <div class="deck-detail-import-actions">
                                <button type="button" class="deck-detail-primary-button" @onclick="ImportCardsAsync" disabled="@(!canImport)">Import</button>
                                <button type="button" class="deck-detail-secondary-button" @onclick="CancelImport">Cancel</button>
                            </div>
                        </section>
                    </div>
                }

                @if (showImportSuccessDialog)
                {
                    <div class="deck-detail-modal-backdrop">
                        <section class="deck-detail-import-modal">
                            <h2>Imported</h2>
                            <p>@importSuccessMessage</p>
                            <div class="deck-detail-import-actions deck-detail-import-actions-end">
                                <button type="button" class="deck-detail-primary-button" @onclick="CloseImportSuccessDialog">OK</button>
                            </div>
                        </section>
                    </div>
                }

                @if (cards.Count == 0)
                {
                    <section class="deck-detail-empty-card">
                        <h2>No cards yet</h2>
                        <p>Add your first card to start studying.</p>
                    </section>
                }
                else
                {
                    <div class="deck-detail-cards">
                        @foreach (var card in cards)
                        {
                            <article class="deck-detail-card">
                                <div class="deck-detail-card-content">
                                    <div class="deck-detail-card-side">
                                        <div class="deck-detail-card-side-label">Front</div>
                                        <div class="deck-detail-card-side-surface">
                                            <div class="deck-detail-card-text">@((MarkupString)card.Front)</div>
                                        </div>
                                    </div>
                                    <div class="deck-detail-card-side">
                                        <div class="deck-detail-card-side-label">Back</div>
                                        <div class="deck-detail-card-side-surface">
                                            <div class="deck-detail-card-text">@((MarkupString)card.Back)</div>
                                        </div>
                                    </div>
                                </div>
                                <div class="deck-detail-card-actions">
                                    <button type="button" class="deck-detail-secondary-button" @onclick="() => GoToEditCard(card.Id)">Edit</button>
                                    <button type="button" class="deck-detail-primary-button" @onclick="() => DeleteCardAsync(card.Id)">Delete</button>
                                </div>
                            </article>
                        }
                    </div>
                }
            </section>
        </div>
    </div>
}

@code {
    [Parameter] public Guid DeckId { get; set; }

    private string deckName = string.Empty;
    private string deckDescription = string.Empty;
    private List<LearningFlashCards.Core.Domain.Entities.Card> cards = [];
    private bool initialized;

    private bool showImportDialog;
    private string? importSummary;
    private string? importError;
    private string? selectedImportFileName;
    private string? importSuccessMessage;
    private bool importHasErrors;
    private bool canImport;
    private bool showStudyDoneMessage;
    private bool showImportSuccessDialog;
    private readonly List<LearningFlashCards.Core.Application.Import.ImportedCardRow> importedCards = new();

    private string DeckDescription => string.IsNullOrWhiteSpace(deckDescription) ? "No description" : deckDescription;
    private string DeckMonogram => GetDeckMonogram(deckName);
    private string ImportFileTitle => string.IsNullOrWhiteSpace(selectedImportFileName) ? "No file selected." : $"Selected: {selectedImportFileName}";
    private string ImportFileBody => string.IsNullOrWhiteSpace(selectedImportFileName) ? "Choose a CSV file to preview." : "Review the summary below before importing.";

    protected override async Task OnInitializedAsync()
    {
        var ownerId = await Session.GetOwnerIdAsync();
        if (!ownerId.HasValue)
        {
            Nav.NavigateTo("/login");
            return;
        }

        var uri = Nav.ToAbsoluteUri(Nav.Uri);
        if (HasStudyDoneFlag(uri.Query))
        {
            showStudyDoneMessage = true;
        }

        await LoadDeckAsync();
        initialized = true;
    }

    private async Task LoadDeckAsync()
    {
        var deck = await Api.GetDeckAsync(DeckId);
        if (deck is null)
        {
            deckName = string.Empty;
            return;
        }

        deckName = deck.Name;
        deckDescription = deck.Description ?? string.Empty;
        cards = await Api.GetCardsAsync(DeckId);
    }

    private async Task OpenImportPicker()
    {
        await Js.InvokeVoidAsync("lfc.openFilePicker", "deck-import-input");
    }

    private void CancelImport()
    {
        showImportDialog = false;
        importSummary = null;
        importError = null;
        selectedImportFileName = null;
        importHasErrors = false;
        canImport = false;
        importedCards.Clear();
    }

    private async Task OnFileSelected(InputFileChangeEventArgs e)
    {
        importError = null;
        importSummary = null;
        canImport = false;
        importedCards.Clear();

        var file = e.File;
        if (file is null)
        {
            return;
        }

        selectedImportFileName = file.Name;
        showImportDialog = true;

        try
        {
            using var stream = file.OpenReadStream(maxAllowedSize: 5 * 1024 * 1024);
            using var reader = new System.IO.StreamReader(stream);
            var content = await reader.ReadToEndAsync();

            var parser = new CsvCardImportParser();
            var result = parser.Parse(content);

            importedCards.AddRange(result.Cards);

            if (result.Cards.Count == 0)
            {
                importSummary = "No valid cards found in the selected file.";
                importHasErrors = true;
                canImport = false;
                return;
            }

            if (result.InvalidRowNumbers.Count > 0)
            {
                var preview = string.Join(", ", result.InvalidRowNumbers.Take(5));
                if (result.InvalidRowNumbers.Count > 5)
                {
                    preview += ", ...";
                }

                importSummary = $"Fix {result.InvalidRowNumbers.Count} rows missing front or back (rows: {preview}).";
                importHasErrors = true;
                canImport = false;
                return;
            }

            importSummary = $"Ready to import {result.Cards.Count} cards.";
            importHasErrors = false;
            canImport = true;
        }
        catch (Exception ex)
        {
            importError = $"Error reading file: {ex.Message}";
            canImport = false;
        }
    }

    private async Task ImportCardsAsync()
    {
        if (importedCards.Count == 0)
        {
            return;
        }

        foreach (var row in importedCards)
        {
            await Api.UpsertCardAsync(DeckId, new { Front = row.Front, Back = row.Back });
        }

        var importedCount = importedCards.Count;
        CancelImport();
        await LoadDeckAsync();
        importSuccessMessage = $"Imported {importedCount} cards.";
        showImportSuccessDialog = true;
    }

    private void CloseImportSuccessDialog()
    {
        showImportSuccessDialog = false;
        importSuccessMessage = null;
    }

    private async Task DeleteCardAsync(Guid cardId)
    {
        await Api.DeleteCardAsync(DeckId, cardId);
        cards = await Api.GetCardsAsync(DeckId);
    }

    private void GoToStudy() => Nav.NavigateTo("/study/" + DeckId);
    private void GoToAddCard() => Nav.NavigateTo("/create-card/" + DeckId);
    private void GoToEditCard(Guid cardId) => Nav.NavigateTo($"/edit-card/{DeckId}/{cardId}");

    private static string GetDeckMonogram(string? deckName)
    {
        var firstCharacter = deckName?.Trim().FirstOrDefault(static c => char.IsLetterOrDigit(c));
        return firstCharacter is null || firstCharacter == default ? "D" : char.ToUpperInvariant(firstCharacter.Value).ToString();
    }

    private static bool HasStudyDoneFlag(string? query)
    {
        if (string.IsNullOrWhiteSpace(query))
        {
            return false;
        }

        var trimmed = query.TrimStart('?');
        foreach (var pair in trimmed.Split('&', StringSplitOptions.RemoveEmptyEntries))
        {
            var parts = pair.Split('=', 2);
            if (parts.Length == 2 &&
                string.Equals(parts[0], "studyDone", StringComparison.OrdinalIgnoreCase) &&
                string.Equals(Uri.UnescapeDataString(parts[1]), "1", StringComparison.Ordinal))
            {
                return true;
            }
        }

        return false;
    }
}
