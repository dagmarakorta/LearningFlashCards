@page "/login"
@rendermode @(new InteractiveWebAssemblyRenderMode(prerender: false))
@inject ApiClient Api
@inject UserSessionService Session
@inject NavigationManager Nav

<PageTitle>Login - LearningFlashCards</PageTitle>

<div class="login-container">
    <div class="login-card">
        <h1>LearningFlashCards</h1>
        <p class="subtitle">Sign in or create an account</p>

        @if (error is not null)
        {
            <div class="alert alert-danger">@error</div>
        }

        <div class="tab-buttons">
            <button class="@(isLogin ? "active" : "")" @onclick="() => { isLogin = true; error = null; }">Login</button>
            <button class="@(!isLogin ? "active" : "")" @onclick="() => { isLogin = false; error = null; }">Register</button>
        </div>

        @if (isLogin)
        {
            <div class="form-group">
                <label>Email</label>
                <input class="form-control" type="email" @bind="loginEmail" placeholder="your@email.com" />
            </div>
            <button class="btn btn-primary w-100" @onclick="LoginAsync" disabled="@isLoading">
                @(isLoading ? "Signing in..." : "Login")
            </button>
        }
        else
        {
            <div class="form-group">
                <label>Name</label>
                <input class="form-control" @bind="registerName" placeholder="Your name" />
            </div>
            <div class="form-group">
                <label>Email</label>
                <input class="form-control" type="email" @bind="registerEmail" placeholder="your@email.com" />
            </div>
            <button class="btn btn-primary w-100" @onclick="RegisterAsync" disabled="@isLoading">
                @(isLoading ? "Registering..." : "Create Account")
            </button>
        }
    </div>
</div>

@code {
    private bool isLogin = true;
    private bool isLoading;
    private string? error;
    private string loginEmail = "";
    private string registerName = "";
    private string registerEmail = "";

    private static readonly System.Text.RegularExpressions.Regex EmailPattern =
        new(@"^[^@\s]+@[^@\s]+\.[^@\s]+$", System.Text.RegularExpressions.RegexOptions.Compiled);
    private static readonly System.Text.RegularExpressions.Regex NamePattern =
        new(@"^[A-Za-z][A-Za-z' -]*$", System.Text.RegularExpressions.RegexOptions.Compiled);

    protected override async Task OnInitializedAsync()
    {
        var ownerId = await Session.GetOwnerIdAsync();
        if (ownerId.HasValue)
            Nav.NavigateTo("/");
    }

    private async Task LoginAsync()
    {
        error = null;
        var email = loginEmail.Trim();
        if (string.IsNullOrWhiteSpace(email))
        {
            error = "Please enter your email.";
            return;
        }

        if (!EmailPattern.IsMatch(email))
        {
            error = "Please enter a valid email address.";
            return;
        }

        isLoading = true;
        try
        {
            var profile = await Api.GetProfileByEmailAsync(email);
            if (profile is null)
            {
                error = "No account found for that email.";
                return;
            }

            await Session.SetOwnerIdAsync(profile.Id);
            Nav.NavigateTo("/");
        }
        catch
        {
            error = "Could not connect to the server.";
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task RegisterAsync()
    {
        error = null;
        var name = registerName.Trim();
        var email = registerEmail.Trim();

        if (string.IsNullOrWhiteSpace(name))
        {
            error = "Please enter your name.";
            return;
        }

        if (name.Length < 3)
        {
            error = "Name must be at least 3 characters.";
            return;
        }

        if (!NamePattern.IsMatch(name))
        {
            error = "Use letters, spaces, apostrophes, or hyphens only.";
            return;
        }

        if (string.IsNullOrWhiteSpace(email))
        {
            error = "Please enter your email.";
            return;
        }

        if (!EmailPattern.IsMatch(email))
        {
            error = "Please enter a valid email address.";
            return;
        }

        isLoading = true;
        try
        {
            var existing = await Api.GetProfileByEmailAsync(email);
            if (existing is not null)
            {
                error = "Email already used. Please login or use a different email.";
                return;
            }

            var profile = await Api.CreateProfileAsync(name, email);
            if (profile is not null)
                Nav.NavigateTo("/");
            else
                error = "Registration failed. Please try again.";
        }
        catch (System.Net.Http.HttpRequestException ex)
        {
            error = $"Registration failed: {ex.Message}";
        }
        finally
        {
            isLoading = false;
        }
    }
}
