@page "/login"
@rendermode @(new InteractiveWebAssemblyRenderMode(prerender: false))
@inject ApiClient Api
@inject UserSessionService Session
@inject NavigationManager Nav

<PageTitle>Login - LearningFlashCards</PageTitle>

<div class="login-container">
    <div class="login-card">
        <h1>LearningFlashCards</h1>
        <p class="subtitle">Sign in or create an account</p>

        @if (error is not null)
        {
            <div class="alert alert-danger">@error</div>
        }

        <div class="tab-buttons">
            <button class="@(isLogin ? "active" : "")" @onclick="() => isLogin = true">Login</button>
            <button class="@(!isLogin ? "active" : "")" @onclick="() => isLogin = false">Register</button>
        </div>

        @if (isLogin)
        {
            <div class="form-group">
                <label>Owner ID</label>
                <input class="form-control" @bind="loginOwnerId" placeholder="Paste your Owner ID (GUID)" />
            </div>
            <button class="btn btn-primary w-100" @onclick="LoginAsync" disabled="@isLoading">
                @(isLoading ? "Signing in..." : "Login")
            </button>
        }
        else
        {
            <div class="form-group">
                <label>Display name</label>
                <input class="form-control" @bind="username" placeholder="e.g. jan.kowalski" />
            </div>
            <div class="form-group">
                <label>Email</label>
                <input class="form-control" type="email" @bind="email" placeholder="email@example.com" />
            </div>
            <button class="btn btn-primary w-100" @onclick="RegisterAsync" disabled="@isLoading">
                @(isLoading ? "Registering..." : "Register")
            </button>
        }
    </div>
</div>

@code {
    private bool isLogin = true;
    private bool isLoading;
    private string? error;
    private string loginOwnerId = "";
    private string username = "";
    private string email = "";

    protected override async Task OnInitializedAsync()
    {
        var ownerId = await Session.GetOwnerIdAsync();
        if (ownerId.HasValue)
        {
            Nav.NavigateTo("/");
        }
    }

    private async Task LoginAsync()
    {
        error = null;
        if (!Guid.TryParse(loginOwnerId, out var id))
        {
            error = "Invalid Owner ID format.";
            return;
        }

        isLoading = true;
        try
        {
            await Session.SetOwnerIdAsync(id);
            var profile = await Api.GetProfileAsync();
            if (profile is null)
            {
                await Session.ClearAsync();
                error = "No account found for that Owner ID.";
                return;
            }

            Nav.NavigateTo("/");
        }
        catch
        {
            await Session.ClearAsync();
            error = "Could not connect to the server.";
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task RegisterAsync()
    {
        error = null;
        if (string.IsNullOrWhiteSpace(username) || string.IsNullOrWhiteSpace(email))
        {
            error = "Provide both display name and email.";
            return;
        }

        isLoading = true;
        try
        {
            await Api.CreateProfileAsync(username, email);
            Nav.NavigateTo("/");
        }
        catch (HttpRequestException ex)
        {
            error = $"Registration failed: {ex.Message}";
        }
        finally
        {
            isLoading = false;
        }
    }
}
